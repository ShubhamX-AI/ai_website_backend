# ==============================================================================
# Indusnet AI Website Backend — environment template
# ------------------------------------------------------------------------------
# Copy to .env and fill in:   cp .env.example .env
# .env is gitignored — never commit real secrets. This file is the safe template.
#
# Legend:
#   [REQUIRED]  process will not work correctly without it (no usable default)
#   [DEFAULT]   has a working default in src/core/config.py; override only if needed
#   [FEATURE]   only needed if you use that tool/feature; missing it disables only
#               that feature, the rest of the stack still boots
# ==============================================================================


# ------------------------------------------------------------------------------
# Core runtime  [REQUIRED] — both API server and agent worker need these
# ------------------------------------------------------------------------------
# LiveKit server credentials (room creation, JWT issuance, agent dispatch)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-host

# OpenAI — realtime conversation LLM + transcription + embeddings
OPENAI_API_KEY=

# Cartesia — text-to-speech (sonic-3)
CARTESIA_API_KEY=


# ------------------------------------------------------------------------------
# Database + Auth  [REQUIRED for auth / token API]
# ------------------------------------------------------------------------------
# MongoDB connection (local or Atlas)
MONGODB_URL=mongodb://localhost:27017       # [DEFAULT] mongodb://localhost:27017
MONGODB_DB_NAME=ai_website                  # [DEFAULT] ai_website

# JWT signing key — REQUIRED in production. Generate: openssl rand -hex 32
SECRET_KEY=

# Client session + access-window durations, in hours
CLIENT_SESSION_HOURS=4                      # [DEFAULT] 4
CLIENT_ACCESS_WINDOW_HOURS=4                # [DEFAULT] 4


# ------------------------------------------------------------------------------
# Google SSO / OAuth  [FEATURE] — needed only for "Sign in with Google"
# Register an OAuth client at https://console.cloud.google.com (APIs & Services
# > Credentials > OAuth client ID, type "Web application").
# Add GOOGLE_REDIRECT_URI to the client's "Authorized redirect URIs".
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google sends the browser back (must match the OAuth client config exactly)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Where FastAPI redirects the browser after it mints the JWT (your Next.js app)
NEXTJS_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Google accounts on this email domain are granted the admin role
ADMIN_DOMAIN=yourcompany.com                # [DEFAULT] intglobal.com


# ------------------------------------------------------------------------------
# Internet search  [FEATURE] — search_internet_knowledge + flashcard images
# Points at a reachable SearXNG instance.
# ------------------------------------------------------------------------------
SEARXNG_BASE_URL=http://127.0.0.1:8090      # [DEFAULT] http://13.126.71.22:4000/


# ------------------------------------------------------------------------------
# Email  [FEATURE] — context email, submission receipts, calendar invites
# For Gmail use an App Password (not your account password).
# ------------------------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com                  # [DEFAULT] smtp.gmail.com
SMTP_PORT=587                               # [DEFAULT] 587
SENDER_EMAIL=your-email@example.com
SENDER_PASSWORD=your-app-password


# ------------------------------------------------------------------------------
# WhatsApp  [FEATURE] — send_context_whatsapp (Meta WhatsApp Cloud API)
# ------------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=utility_agui_agent   # [DEFAULT] utility_agui_agent


# ------------------------------------------------------------------------------
# Maps  [FEATURE] — request_user_location + calculate_distance_to_destination
# Google Maps API key with Distance Matrix / Directions enabled.
# ------------------------------------------------------------------------------
GOOGLE_API_KEY=


# ------------------------------------------------------------------------------
# Optional tuning  [DEFAULT]
# ------------------------------------------------------------------------------
PORT=8000                                   # [DEFAULT] 8000
EMAIL_SUMMARY_MODEL=gpt-4o-mini             # [DEFAULT] gpt-4o-mini
